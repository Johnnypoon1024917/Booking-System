<?xml version="1.0" encoding="UTF-8"?>
<!--
  FSD MRBS — Outlook add-in manifest.

  This is a Mailbox add-in (Office.js) that exposes a "Book a Room" task
  pane in the Outlook ribbon when composing a meeting. The pane lets the
  organiser search MRBS resources, confirm a slot, and inserts the
  resource as a Required Attendee plus an MRBS booking-ID line into the
  meeting body. Once installed the user is signed in via the same SSO
  token MRBS issues; tokens flow through the Office dialog API so the
  add-in never sees credentials directly.

  Replace `{PUBLIC_BASE_URL}` with the externally-reachable HTTPS origin
  the SPA is served from before sideloading or publishing via the
  Microsoft 365 admin centre. SourceLocation must be HTTPS in production.
-->
<OfficeApp
    xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
    xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="MailApp">

  <Id>9c1e6f48-5d8d-4f6f-b39e-fsdmrbs-outlook</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>FSD Hong Kong</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="FSD MRBS — Book a Room" />
  <Description DefaultValue="Search and book FSD meeting rooms, vehicles, and equipment without leaving Outlook." />
  <IconUrl DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/icon-128.png" />
  <SupportUrl DefaultValue="{PUBLIC_BASE_URL}/help/outlook" />

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.10" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.10">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="ShowTaskPaneButton">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Taskpane.Url" DefaultValue="{PUBLIC_BASE_URL}/outlook-addin/taskpane.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="FSD MRBS" />
          <bt:String id="TaskpaneButton.Label" DefaultValue="Book a Room" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the MRBS task pane to search and reserve resources for this meeting." />
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
